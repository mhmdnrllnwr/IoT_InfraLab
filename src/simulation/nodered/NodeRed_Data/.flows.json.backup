        "func": "msg.topic = 'system_log';\nif (msg.statusCode >= 200 && msg.statusCode < 300) {\n    msg.payload = \"🔒 MOSQUITTO EVENT: \" + msg.notification_text;\n} else {\n    msg.payload = `❌ MOSQUITTO ERROR: Failed to restart broker (API returned ${msg.statusCode})`;\n}\nreturn msg;",
