    {
        "id": "9870adbace0b3c6d",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Activate Stream",
        "func": "let target = flow.get('cfg_monitor_node');\nif (!target) { msg.payload = \"⚠️ ERROR: No sensor selected.\"; return msg; }\n\nflow.set('sensor_monitor_active', true);\nflow.set('mqtt_terminal_logs', []);\nmsg.payload = `[SYSTEM] Connected to Mosquitto Broker.\\nListening for MQTT telemetry matching [${target}]...`;\nreturn msg;",
        "outputs": 1,
        "x": 380,
        "y": 1140,
        "wires": [
            [
                "b577b406436de1c3"
            ]
        ]
    },
    {
        "id": "4b6b8f7d5b48186e",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Deactivate Stream",
        "func": "let target = flow.get('cfg_monitor_node') || 'sensor';\nflow.set('sensor_monitor_active', false);\nmsg.payload = `[SYSTEM] Filter deactivated.\\nStopped listening for [${target}].`;\nreturn msg;",
        "outputs": 1,
        "x": 370,
        "y": 1200,
        "wires": [
            [
                "b577b406436de1c3"
            ]
        ]
    },
    {
        "id": "239b3cfa5ea187ca",
        "type": "mqtt in",
        "z": "89c26b2630a7d108",
        "name": "Subscribe: All Traffic (#)",
        "topic": "#",
        "qos": "0",
        "datatype": "auto-detect",
        "broker": "9956a4644cc28f0f",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 160,
        "y": 1260,
        "wires": [
            [
                "3743e72af9692d86"
            ]
        ]
    },
    {
        "id": "3743e72af9692d86",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Smart Filter",
        "func": "let active = flow.get('sensor_monitor_active');\nlet target = flow.get('cfg_monitor_node');\nif (!active || !target) return null;\n\nlet topic = msg.topic;\nlet payloadStr = typeof msg.payload === 'object' ? JSON.stringify(msg.payload) : String(msg.payload);\n\nif (topic.includes(target) || payloadStr.includes(target)) {\n    let time = new Date().toLocaleTimeString();\n    if (typeof msg.payload === 'object') {\n        payloadStr = JSON.stringify(msg.payload, null, 2);\n    }\n    let logEntry = `[${time}] Topic: ${topic}\\n${payloadStr}`;\n    let logs = flow.get('mqtt_terminal_logs') || [];\n    logs.push(logEntry);\n    if (logs.length > 5) logs.shift();\n    flow.set('mqtt_terminal_logs', logs);\n    msg.payload = logs.join('\\n----------------------------------\\n');\n    return msg;\n}\nreturn null;",
        "outputs": 1,
        "x": 390,
        "y": 1260,
        "wires": [
            [
                "b577b406436de1c3"
            ]
        ]
    },
    {
        "id": "b577b406436de1c3",
        "type": "ui-template",
        "z": "89c26b2630a7d108",
        "group": "ui_group_sensor_monitor",
        "page": "",
        "ui": "",
        "name": "MQTT Data Terminal",
        "order": 1,
        "width": 0,
        "height": 0,
        "format": "<div style=\"background:#1e1e1e; border: 1px solid #333; border-radius:8px; box-shadow: 0 4px 15px rgba(0,0,0,0.5); margin-top: 5px;\">\n    <div style=\"background:#2d2d2d; padding:8px 15px; border-bottom:1px solid #444; border-radius: 8px 8px 0 0; color:#888; font-family:sans-serif; font-size:12px; display:flex; align-items:center;\">\n       <div style=\"display:flex; gap:8px;\">\n           <div style=\"width:10px;height:10px;border-radius:50%;background:#ff5f56;\"></div>\n           <div style=\"width:10px;height:10px;border-radius:50%;background:#ffbd2e;\"></div>\n           <div style=\"width:10px;height:10px;border-radius:50%;background:#27c93f;\"></div>\n       </div>\n       <span style=\"margin-left:15px; color:#a3a3a3; font-weight:500;\"><i class=\"fa fa-wifi\"></i> mosquitto-broker-stream</span>\n    </div>\n    <pre style=\"color:#22d3ee; padding:15px; height:240px; overflow-y:auto; font-family:'Fira Code', 'Courier New', monospace; font-size:13px; margin:0; white-space:pre-wrap; line-height: 1.4;\" v-text=\"msg.payload||'Broker connection pending...' \"></pre>\n</div>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 640,
        "y": 1180,
        "wires": [
            []
        ]
    },
    {
        "id": "04553eb8843ef23e",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Verify Selection",
        "func": "let target_id = flow.get('cfg_target_del_id');\nif(!target_id || target_id === 'none') {\n    return [null, { payload: \"⚠️ Error: No configuration selected to delete!\" }];\n}\nreturn [msg, null];",
        "outputs": 2,
        "x": 130,
        "y": 1360,
        "wires": [
