    {
        "id": "e56869580375d8ba",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Filter Multiple Deletes",
        "func": "let target_ids = flow.get('cfg_target_del_ids');\n\n// Check if array exists and has elements\nif(!target_ids || !Array.isArray(target_ids) || target_ids.length === 0) {\n    return [null, { payload: \"⚠️ Error: No configurations selected to delete!\" }];\n}\n\nlet configs = [];\ntry { \n    if(msg.payload) configs = JSON.parse(msg.payload); \n} catch(e) { }\n\n// Filter out ANY config whose ID exists in the target_ids array\nlet filtered = configs.filter(c => !target_ids.includes(c.id));\nmsg.payload = JSON.stringify(filtered, null, 2);\n\n// Clear the selection after processing\nflow.set('cfg_target_del_ids', []);\n\nreturn [msg, { payload: `🗑️ Deleted configs: [${target_ids.join(', ')}]` }];",
        "outputs": 2,
        "x": 520,
        "y": 700,
        "wires": [
            [
                "14587dad53056061"
            ],
            []
        ]
    },
