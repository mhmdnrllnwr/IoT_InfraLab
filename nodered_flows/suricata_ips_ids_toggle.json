[
    {
        "id": "suricata_ips_switch",
        "type": "ui_switch",
        "name": "Suricata IPS Mode",
        "label": "Suricata IPS Mode",
        "tooltip": "Toggle between IDS (Alert) and IPS (Reject)",
        "group": "",
        "order": 1,
        "width": 0,
        "height": 0,
        "passthru": true,
        "decouple": "false",
        "topic": "topic",
        "topicType": "msg",
        "style": "",
