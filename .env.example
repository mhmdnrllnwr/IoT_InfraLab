# === REQUIRED: Google Gemini API Key ===
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# === REQUIRED: InfluxDB Admin Token ===
# Generate with: openssl rand -hex 32
INFLUXDB_TOKEN=generate_a_secure_token_here

# === InfluxDB Initial Setup ===
# Only used on first run when influxdb data volume is empty.
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=change_this_password
DOCKER_INFLUXDB_INIT_ORG=infralab
DOCKER_INFLUXDB_INIT_BUCKET=sensor_data
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=generate_a_secure_token_here

# === Grafana Admin Credentials ===
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_this_password

# === Node-RED Credential Encryption ===
NODE_RED_CREDENTIAL_SECRET=change_this_secret

# === Optional: Project Path for Host Bind Mounts ===
# On Linux/macOS: absolute path to project root, e.g. /home/user/IoT_InfraLab
# On Windows: full path with forward slashes, e.g. C:/Users/user/IoT_InfraLab
# On Docker Desktop all platforms: leave as . (Docker Desktop auto-resolves)
IOT_PROJECT_PATH=.

# === Optional: Docker Network Subnet ===
# Change if 172.18.0.0/24 conflicts with your network.
IOT_SUBNET=172.18.0.0/24
