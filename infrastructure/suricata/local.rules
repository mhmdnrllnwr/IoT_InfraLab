# ==========================================
# local.rules.ids - IDS MODE (Alert Only)
# ==========================================

# Safelist internal management traffic
pass ip 172.18.0.100 any <> any any (msg:"Safelisting Security Auditor"; sid:9900001; rev:1;)
pass ip 172.18.0.25 any <> any any (msg:"Safelisting Node-RED"; sid:9900002; rev:1;)
pass ip 172.18.0.10 any <> any any (msg:"Safelisting Promtail"; sid:9900003; rev:1;)

# 1. MQTT SYN Flood (DoS)
alert tcp any any -> any 1883 (msg:"DoS Attempt: MQTT SYN Flood Detected"; flow:to_server,stateless; flags:S; threshold:type both, track by_src, count 100, seconds 1; classtype:attempted-dos; sid:1000001; rev:2;)

# 2. Nmap Port Scan (Stealth SYN)
alert tcp any any -> any any (msg:"Nmap SYN Stealth Scan Detected"; flow:stateless; flags:S; threshold:type both, track by_src, count 3, seconds 5; classtype:attempted-recon; sid:1000002; rev:2;)

# 3. Protocol Mismatch (Telemetry Injection with HTTP methods)
alert tcp any any -> any 1883 (msg:"Protocol Mismatch: HTTP Method sent to MQTT Broker"; flow:to_server,established; pcre:"/^(GET|POST|PUT|DELETE)\\s+/i"; classtype:protocol-command-decode; sid:1000003; rev:2;)

# 4a. Rogue Subscriber (Native MQTT Parser - Commented Out)
# alert mqtt any any -> any 1883 (msg:"Rogue Subscriber Detected: Native MQTT Wildcard '#'"; mqtt.subscribe.topic:"#"; classtype:attempted-recon; sid:1000005; rev:2;)

# 4b. Rogue Subscriber (Raw TCP Fallback)
alert tcp any any -> any 1883 (msg:"Rogue Subscriber Detected: Raw Hex Wildcard '#'"; flow:to_server; content:"|00 01 23|"; classtype:attempted-recon; sid:1000007; rev:2;)
