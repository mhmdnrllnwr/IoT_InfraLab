    {
        "id": "913093a5c65980f2",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Spawn Splitters",
        "func": "let configs = [];\ntry { if (msg.payload) configs = JSON.parse(msg.payload); } catch(e) {}\nif(configs.length === 0) return null;\n\nlet delay = 0;\nlet msgs = [];\n// We create multiple msg objects that will fire sequentially into the docker node\nconfigs.forEach(cfg => {\n    msgs.push({ \n        payload: cfg,\n        delay: delay\n    }); \n    delay += 2000; // 2 seconds between creation\n});\nreturn [msgs];",
        "outputs": 1,
        "x": 560,
        "y": 620,
        "wires": [
            [
                "2fda066a281289cf"
            ]
        ]
