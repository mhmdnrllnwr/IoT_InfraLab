    {
        "id": "0b159f4717a62910",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Filter Delete",
        "func": "let target_id = flow.get('cfg_target_del_id');\nlet configs = [];\n\ntry { \n    if(msg.payload) configs = JSON.parse(msg.payload); \n} catch(e) { }\n\nlet filtered = configs.filter(c => c.id !== target_id);\nmsg.payload = JSON.stringify(filtered, null, 2);\n\n// Clear the current selection so we don't accidentally double delete\nflow.set('cfg_target_del_id', null);\n\nreturn [msg, { payload: `🗑️ Deleted saved configuration: [${target_id}]` }];",
        "outputs": 2,
        "x": 490,
        "y": 1360,
        "wires": [
