    {
        "id": "c7ef7b0e1f9143ef",
        "type": "function",
        "z": "53b83243ce3bfc91",
        "name": "Auto-Isolate Trigger",
        "func": "let isAuto = flow.get('nac_auto');\n// FIX 1: Safely handle both boolean and string representations from the dashboard switch\nif (isAuto !== true && isAuto !== \"true\") return null;\n\nlet attackers = msg.payload || [];\nif (attackers.length === 0) return null;\n\nlet ipMap = flow.get('network_ip_map') || {};\nlet isolated = flow.get('auto_isolated') || {};\nlet apiMsgs = [];\nlet uiMsgs = [];\nlet now = Date.now();\n\nattackers.forEach(ip => {\n    // FIX 2: If the IP map hasn't updated fast enough to catch the attacker, fallback to the lab default name\n    let container = ipMap[ip] || \"iot_attacker_node\";\n\n    // FIX 3: 30-Second Cooldown. Instead of locking forever, allow re-isolation after 30 seconds for lab testing\n    if (container && (!isolated[container] || (now - isolated[container] > 30000))) {\n        isolated[container] = now;\n        apiMsgs.push({\n            url: 'http://docker-proxy:2375/networks/iot_infralab_net/disconnect',\n            method: 'POST',\n            payload: { \"Container\": container, \"Force\": true },\n            containerName: container\n        });\n        uiMsgs.push({ topic: 'system_log', payload: `⚡ [ACTIVE NAC] Threat detected! Auto-isolating ${container} (${ip})...` });\n    }\n});\n\nflow.set('auto_isolated', isolated);\n\nif (apiMsgs.length > 0) return [apiMsgs, uiMsgs];\nreturn null;",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 240,
        "wires": [
            [
                "d23401a13c109ee0"
            ],
            [
                "5a9e7b1d4c3ffce4"
            ]
        ]
    },
