    {
        "id": "helps_tour_toggle",
        "type": "ui-template",
        "z": "89c26b2630a7d108",
        "group": "ui_group_helps",
        "page": "",
        "ui": "",
        "name": "Tour Toggle",
        "order": 1,
        "width": "0",
        "height": "0",
        "format": "<div style=\"background:#1e1e1e;border-radius:8px;padding:24px;color:#e0e0e0;\">\n  <div style=\"text-align:center;margin-bottom:20px;\">\n    <div id=\"hlp-status\" style=\"font-size:18px;font-weight:600;margin-bottom:8px;\">Checking...</div>\n    <div id=\"hlp-desc\" style=\"font-size:13px;color:#999;margin-bottom:12px;\">Node Management tour</div>\n    <button id=\"hlp-btn\" style=\"padding:10px 28px;border:none;border-radius:6px;font-size:15px;cursor:pointer;color:#fff;\">Loading...</button>\n  </div>\n  <hr style=\"border-color:#444;margin:16px 0;\">\n  <div style=\"text-align:center;\">\n    <div id=\"hlp-soc-status\" style=\"font-size:18px;font-weight:600;margin-bottom:8px;\">Checking...</div>\n    <div id=\"hlp-soc-desc\" style=\"font-size:13px;color:#999;margin-bottom:12px;\">Security Operations tour</div>\n    <button id=\"hlp-soc-btn\" style=\"padding:10px 28px;border:none;border-radius:6px;font-size:15px;cursor:pointer;color:#fff;\">Loading...</button>\n  </div>\n</div>\n<img src=\"x\" style=\"display:none\" onerror=\"\n(function(){\n  if(window.__hlp) return; window.__hlp=1;\n  setTimeout(function(){\n    function makeToggle(stId,descId,btnId,key,page){\n      var st=document.getElementById(stId);\n      var desc=document.getElementById(descId);\n      var btn=document.getElementById(btnId);\n      if(!st||!btn) return;\n      function update(){\n        var done=localStorage.getItem(key);\n        if(!done){\n          st.textContent='Tour Active';\n          desc.textContent='Will auto-play on '+page+' page';\n          btn.textContent='Reset Tour';\n          btn.style.background='#10b981';\n        } else {\n          st.textContent='Tour Completed';\n          desc.textContent='Tour already shown on '+page;\n          btn.textContent='Re-enable Tour';\n          btn.style.background='#0094CE';\n        }\n      }\n      update();\n      btn.onclick=function(){ localStorage.removeItem(key); update(); };\n    }\n    makeToggle('hlp-status','hlp-desc','hlp-btn','tour_nm_done','Node Management');\n    makeToggle('hlp-soc-status','hlp-soc-desc','hlp-soc-btn','tour_soc_done','Security Operations');\n  },600);\n})();\n\">",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
