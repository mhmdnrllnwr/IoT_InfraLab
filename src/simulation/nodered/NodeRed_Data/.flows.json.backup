        "wires": []
    },
    {
        "id": "0a3d5de1d4fa2473",
        "type": "function",
        "z": "4acab47cf7e84e94",
        "name": "Format Data",
        "func": "let sensorData = msg.payload;\n\n// Create an array to hold all the InfluxDB data points\nlet influxPayload = [];\n\n// Loop through each sensor type (e.g., temperature, vibration) in the 'readings' object\nfor (const [sensorType, value] of Object.entries(sensorData.readings)) {\n    influxPayload.push([\n        // 1. The Fields (The actual numbers we want to graph)\n        {\n            value: value\n        },\n        // 2. The Tags (This tells InfluxDB everything it needs to know to separate the data)\n        {\n            sensor_id: sensorData.sensor_id,\n            sensor_type: sensorType,\n            profile: sensorData.profile\n        }\n    ]);\n}\n\n// Overwrite msg.payload with the formatted array InfluxDB expects\nmsg.payload = influxPayload;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 370,
        "y": 100,
        "wires": [
            [
                "030bec7b7de86264"
            ]
        ]
    },
