    {
        "id": "b7af56a8e067e375",
        "type": "function",
        "z": "c350aeb8fed5a51f",
        "name": "Spawn Splitters",
        "func": "let configs = [];\ntry { if (msg.payload) configs = JSON.parse(msg.payload); } catch(e) {}\nif(configs.length === 0) {\n    return [null, { payload: \"⚠️ [VALIDATION FAILED] No saved configurations exist. Cannot Mass Deploy.\" }];\n}\n\nlet delay = 0;\nlet msgs = [];\nconfigs.forEach(cfg => {\n    msgs.push({ \n        payload: cfg,\n        delay: delay\n    }); \n    delay += 2000;\n});\nreturn [msgs, { payload: `🚀 Starting sequential Mass Deploy of ${configs.length} sensors...` }];",
