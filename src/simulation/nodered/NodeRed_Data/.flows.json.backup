    {
        "id": "08d97859a5d29e9d",
        "type": "function",
        "z": "53b83243ce3bfc91",
        "name": "Prep Manual Disconnect",
        "func": "let target = flow.get('soc_target');\nif(!target) return [null, {payload: \"⚠️ Select an IP from the dropdown first!\"}];\n\nlet apiMsg = {\n    url: 'http://docker-proxy:2375/networks/iot_infralab_net/disconnect',\n    method: 'POST',\n    payload: { \"Container\": target, \"Force\": true },\n    containerName: target\n};\n\n// Mark as isolated so auto-mode doesn't try it again later\nlet isolated = flow.get('auto_isolated') || {};\nisolated[target] = true;\nflow.set('auto_isolated', isolated);\n\nreturn [apiMsg, {payload: `Manual NAC: Isolating ${target}...`}];",
        "outputs": 2,
        "x": 390,
        "y": 300,
        "wires": [
