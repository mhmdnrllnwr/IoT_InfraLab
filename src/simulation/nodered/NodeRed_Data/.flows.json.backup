        "func": "msg.topic = 'system_log';\nif(msg.statusCode === 200 || msg.statusCode === 204 || msg.statusCode === 500) {\n    msg.payload = `✅ NAC ACTION: Successfully isolated container [${msg.containerName}] from the network.`;\n} else {\n    msg.payload = `❌ NAC FAILED: Could not isolate target. Status: ${msg.statusCode}`;\n}\nreturn msg;",
