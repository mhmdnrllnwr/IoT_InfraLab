    {
        "id": "a32b63ed2ad62aa1",
        "type": "ui-switch",
        "z": "53b83243ce3bfc91",
        "name": "NAC Auto-Protect Mode",
        "label": "Auto-Isolate Attackers (Active NAC)",
        "group": "8356bd12d00a4d35",
        "order": 3,
        "width": 0,
        "height": 0,
        "passthru": true,
        "decouple": false,
        "topic": "nac_mode",
        "onvalue": "true",
        "onvalueType": "bool",
        "offvalue": "false",
