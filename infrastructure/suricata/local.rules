# Custom Suricata Rules for IoT Lab

# Allow all traffic from the Auditor IP (172.18.0.5) to any destination
pass ip 172.18.0.5 any <> any any (msg:"Safelisting Security Auditor"; sid:9900001; rev:1;)

# 1. MQTT SYN Flood (DoS)
# Alerts if a single source IP sends more than 100 SYN packets per second to port 1883
alert tcp any any -> any 1883 (msg:"DoS Attempt: MQTT SYN Flood Detected"; flow:to_server,stateless; flags:S; threshold:type both, track by_src, count 100, seconds 1; classtype:attempted-dos; sid:1000001; rev:1;)

# 2. Nmap Port Scan (Stealth SYN)
# Alerts on rapid sequential port probing
alert tcp any any -> any any (msg:"Nmap SYN Stealth Scan Detected"; flow:stateless; flags:S; threshold:type both, track by_src, count 3, seconds 5; classtype:attempted-recon; sid:1000002; rev:2;)

# 3. Protocol Mismatch (Telemetry Injection with HTTP methods)
# Alerts if cleartext standard HTTP methods are sent to the MQTT broker
alert tcp any any -> any 1883 (msg:"Protocol Mismatch: HTTP Method sent to MQTT Broker"; flow:to_server,established; pcre:"/^(GET|POST|PUT|DELETE)\s+/i"; classtype:protocol-command-decode; sid:1000003; rev:1;)

# 4a. Rogue Subscriber (Native MQTT Parser)
# This uses Suricata's built-in MQTT decoder. It doesn't care about hex bytes, it just reads the topic.
alert mqtt any any -> any 1883 (msg:"Rogue Subscriber Detected: Native MQTT Wildcard '#'"; mqtt.subscribe.topic:"#"; classtype:attempted-recon; sid:1000005; rev:2;)

# 4b. Rogue Subscriber (Raw TCP Fallback)
# If the native parser is disabled, this raw hex check acts as a backup. 
# Notice we removed the "established" keyword so it catches the packet even if Docker drops the handshake state.
alert tcp any any -> any 1883 (msg:"Rogue Subscriber Detected: Raw Hex Wildcard '#'"; flow:to_server; content:"|00 01 23|"; classtype:attempted-recon; sid:1000007; rev:1;)