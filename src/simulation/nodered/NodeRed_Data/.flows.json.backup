        "name": "Hacker Terminal",
        "order": 1,
        "width": 0,
        "height": 0,
        "format": "<template>\n    <div class=\"hacker-terminal\">\n        <div v-html=\"msg.payload || '<span class=\\'prompt\\'>root@iot-attacker:~#</span> <span class=\\'waiting-text\\'>Awaiting target node deployment...</span>'\"></div>\n    </div>\n</template>\n\n<style>\n.hacker-terminal {\n    background: #0f172a;\n    padding: 15px;\n    height: 100%;\n    min-height: 450px;\n    overflow-y: auto;\n    font-family: monospace;\n    margin: 0;\n    border-radius: 4px;\n    box-sizing: border-box;\n    color: #10b981; /* Default terminal green */\n}\n.prompt { color: #38bdf8; font-weight: bold; }\n.cmd-text { color: #f8fafc; }\n.output-success { color: #10b981; white-space: pre-wrap; margin-top: 10px; }\n.output-blocked { color: #94a3b8; white-space: pre-wrap; margin-top: 10px; }\n.waiting-text { color: #64748b; }\n.alert-box {\n    color: #ef4444;\n    font-weight: bold;\n    padding: 10px;\n    border: 1px solid #ef4444;\n    background: rgba(239, 68, 68, 0.1);\n    border-radius: 4px;\n    margin-top: 15px;\n}\n.alert-sub {\n    font-size: 12px;\n    color: #fca5a5;\n    font-weight: normal;\n}\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1600,
        "y": 300,
        "wires": [
            []
        ]
    },
    {
        "id": "f9c9ced707da3789",
        "type": "function",
        "z": "b78d14cc362e1196",
        "name": "Prep Exec Target",
        "func": "let cmd = msg.cmd;\n\n// SAVE THE COMMAND: Store it so the terminal can print what was just run\nmsg.executed_cmd = cmd.join(' ');\n\nmsg.url = 'http://docker-proxy:2375/containers/iot_attacker_node/exec';\nmsg.method = 'POST';\nmsg.timeout = 300000;\nmsg.payload = {\n  'AttachStdout': true,\n  'AttachStderr': true,\n  'Tty': true,\n  'Cmd': cmd\n};\nreturn msg;",
        "outputs": 1,
        "x": 610,
        "y": 260,
        "wires": [
            [
                "b19e09082a24eb43"
            ]
        ]
    },
    {
        "id": "b93b4da2d3aa8772",
        "type": "function",
        "z": "b78d14cc362e1196",
        "name": "Buffer to Terminal Format",
        "func": "let rawCmd = msg.executed_cmd || \"unknown command\";\n\n// 1. Reconstruct the dynamic terminal prompt using CSS classes\nlet output = `<span class=\"prompt\">root@iot-attacker:~#</span> <span class=\"cmd-text\">${rawCmd}</span><br>`;\n\nif (typeof msg.payload === 'object') {\n    msg.payload = JSON.stringify(msg.payload, null, 2);\n}\n\nlet resultText = msg.payload || \"\";\nif (resultText.trim() === \"\") {\n    resultText = \"[+] Execution finished successfully (No terminal output returned).\";\n}\n\n// 2. Threat Analysis: Smarter detection for IPS/NAC blocks\nlet isBlocked = false;\nlet lowerResult = resultText.toLowerCase();\n\n// Look for definitive network disconnects or firewall drops, \n// completely ignoring standard numbers like '104' to prevent false positives.\nif (lowerResult.includes(\"host seems down\") || \n    (lowerResult.includes(\"filtered\") && rawCmd.includes(\"nmap\")) || \n    lowerResult.includes(\"connection refused\") ||\n    lowerResult.includes(\"reset by peer\") ||\n    lowerResult.includes(\"[errno 104]\") ||\n    lowerResult.includes(\"error 104\")) { \n    isBlocked = true;\n}\n\n// 3. Format the raw output (Escape HTML tags)\nresultText = resultText.replace(/</g, \"&lt;\").replace(/>/g, \"&gt;\");\nlet outputClass = isBlocked ? \"output-blocked\" : \"output-success\";\noutput += `<div class=\"${outputClass}\">${resultText}</div>`;\n\n// 4. Inject the Red Blocked Alert ONLY if actually blocked\nif (isBlocked) {\n    output += `<div class=\"alert-box\">`;\n    output += `🚨 EXPLOIT FAILED: CONNECTION INTERCEPTED BY IPS/NAC 🚨<br>`;\n    output += `<span class=\"alert-sub\">The target forcefully rejected the attack (Dropped packets / TCP Reset / Connection Severed).</span>`;\n    output += `</div>`;\n}\n\nmsg.payload = output;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1470,
        "y": 260,
        "wires": [
            [
                "b06b645f5d9bfd12"
            ]
        ]
    },
    {
        "id": "030bec7b7de86264",
        "type": "influxdb out",
        "z": "4acab47cf7e84e94",
        "influxdb": "17435d09976b7d21",
        "name": "Write to Influxdb",
        "measurement": "sensor_data",
        "precision": "",
        "retentionPolicy": "",
        "database": "database",
        "precisionV18FluxV20": "ms",
        "retentionPolicyV18Flux": "",
        "org": "IoT-InfraLab",
