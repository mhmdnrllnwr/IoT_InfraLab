        "name": "Update All Dropdowns",
        "func": "let data = {};\ntry {\n    data = JSON.parse(msg.payload);\n} catch(e) { return null; }\n\nglobal.set('sensorTypesDB', data);\n\nlet opts = Object.keys(data).map(key => ({\n    label: key.charAt(0).toUpperCase() + key.slice(1).replace(/_/g, ' '),\n    value: key\n}));\n\nmsg.options = opts;\nmsg.payload = \"\";\nreturn msg;",
