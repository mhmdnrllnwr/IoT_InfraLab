        "type": "function",
        "z": "c350aeb8fed5a51f",
        "name": "Format JSON->HTML/Dropdown",
        "func": "let configs = [];\ntry {\n    if (msg.payload) configs = JSON.parse(msg.payload);\n} catch(e) {}\n\nlet html = '<table style=\"width:100%; text-align:left; border-collapse:collapse;\"><tr style=\"border-bottom:1px solid #555;\"><th style=\"padding:4px;\">ID</th><th style=\"padding:4px;\">Profile</th><th style=\"padding:4px;\">Sensors</th></tr>';\nlet dd_opts = [];\n\nif(configs.length > 0){\n    configs.forEach(c => {\n        html += `<tr style=\"border-bottom:1px solid #333;\"><td style=\"padding:4px;color:#60a5fa;\">${c.id}</td><td style=\"padding:4px;\">${c.profile}</td><td style=\"padding:4px;font-size:0.85em;color:#aaa;\">${c.types}</td></tr>`;\n        dd_opts.push({label: c.id, value: c.id, type: 'str'});\n    });\n} else {\n    html += '<tr><td colspan=\"3\" style=\"text-align:center;padding:10px;\">No saved configs</td></tr>';\n    dd_opts = [{label: \"No Configs\", value: \"none\", type: \"str\"}];\n}\nhtml += '</table>';\n\nreturn [{payload: html}, {options: dd_opts}];",
