    {
        "id": "c5c5aa378e457bbc",
        "type": "function",
        "z": "d8c6953bcf076db9",
        "name": "Prep Docker Disconnect",
        "func": "let target = flow.get('soc_target');\nif(!target) {\n    return [null, {payload: \"⚠️ Please select an IP address from the dropdown first.\"}];\n}\n\nmsg.url = 'http://docker-proxy:2375/networks/iot_infralab_net/disconnect';\nmsg.method = 'POST';\nmsg.payload = {\n    \"Container\": target,\n    \"Force\": true\n};\n\nlet log = { payload: `Executing Network Isolation (NAC) on node ID: [${target}]...` };\nreturn [msg, log];",
