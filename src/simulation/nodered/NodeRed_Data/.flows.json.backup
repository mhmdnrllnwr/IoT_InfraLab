    {
        "id": "tour_node_mgmt",
        "type": "ui-template",
        "z": "89c26b2630a7d108",
        "group": "ui_group_create",
        "name": "Tour: Node Management",
        "order": 7,
        "width": 0,
        "height": 0,
        "format": "<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css\"/>\n<img src=\"x\" style=\"display:none\" onerror=\"\n(function(){\n  if(window.__tnm) return; window.__tnm=1;\n  if(localStorage.getItem('tour_nm_done')) return;\n  var s=document.createElement('script');\n  s.src='https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js';\n  s.onload=function(){\n    setTimeout(function(){\n      var d=window.driver.js.driver({\n        showProgress:true,\n        animate:true,\n        opacity:0.75,\n        allowClose:true,\n        stagePadding:10,\n        popoverOffset:10,\n        steps:[\n{element:'#nrdb-ui-group-e900fa4283c2f1cd',popover:{title:'Manage Sensor Type',description:'Define custom sensor types with name, value range, and measurement units.',side:'top',align:'start'}},\n{element:'#nrdb-ui-widget-554a1a12eae4d72b',popover:{title:'1-1. Select Type',description:'Load an existing sensor type to edit, or create a new one from scratch.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-b2eb713f526ac7dd',popover:{title:'1-2. Editor Form',description:'Set sensor type name, min value, and max value. Saved types appear in the Sensor Types dropdown.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-d6643cfede4e4159',popover:{title:'1-3. Delete Type',description:'Remove a custom sensor type. Built-in types cannot be deleted.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-group-ui_group_create',popover:{title:'Create Sensor Node',description:'Deploy new IoT sensor containers. This form configures and launches a sensor.',side:'top',align:'start'}},\n{element:'#nrdb-ui-widget-599a1bcf052a2d6b',popover:{title:'2-1. Node ID',description:'Unique name for your sensor (e.g. factory_pump_1). Used as the MQTT topic prefix.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-84229573cbb609c6',popover:{title:'2-2. Sensor Types',description:'Pick one or more sensor types to simulate (temperature, humidity, pressure, etc).',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-e34b9ac4c76bbf2b',popover:{title:'2-3. Behavior Profile',description:'Normal = steady readings. Failing = gradual decay. Erratic = random spikes.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-d6e9ef46aea2ca6f',popover:{title:'2-4. Publish Interval',description:'How often (seconds) data is sent to MQTT. Lower = more frequent updates.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-42a84a202cae8c2b',popover:{title:'2-5. Run & Save',description:'Deploys your sensor. Saves config and launches a Docker container.',side:'left',align:'start'}},\n{element:'#nrdb-ui-group-ui_group_deploy_log',popover:{title:'Deployment Log',description:'Real-time terminal output from sensor deployments, starts, and stops.',side:'top',align:'start'}},\n{element:'#nrdb-ui-widget-d7dfe950f06ff51b',popover:{title:'3-1. Terminal',description:'Shows container creation logs, MQTT connections, and sensor data in real time.',side:'left',align:'start'}},\n{element:'#nrdb-ui-group-2a7528eec5f798b0',popover:{title:'Saved Configurations',description:'View, re-deploy, or delete previously saved sensor configurations.',side:'top',align:'start'}},\n{element:'#nrdb-ui-widget-a0e4ce86e61d7e70',popover:{title:'4-1. Configs Table',description:'Lists all saved sensor configs with ID, profile type, and sensor types.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-24a2a0c33fcea25b',popover:{title:'4-2. Select to Delete',description:'Pick one or more saved configs to remove from the list.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-59d08ebc14ded4c9',popover:{title:'4-3. Delete Selected',description:'Removes the chosen config(s) from the saved list permanently.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-6aaf537eb1e62b1c',popover:{title:'4-4. Run ALL Saved',description:'Mass-deploy every saved config at once. Containers launch 2 seconds apart.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-dd8c797c7b829981',popover:{title:'4-5. Remove All',description:'Clears the entire saved configuration list. Cannot be undone.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-group-ui_group_node_control',popover:{title:'Node Control',description:'Control active sensor containers: start, stop, restart, or force-kill.',side:'top',align:'start'}},\n{element:'#nrdb-ui-widget-a9b32cc95c805692',popover:{title:'5-1. Target Node',description:'Select which running sensor container to control.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-a56f2bec522482e9',popover:{title:'5-2. Action',description:'Choose command: Start, Stop, Kill, Pause, Unpause, Restart, or Delete.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-3f1c960a7aec12de',popover:{title:'5-3. Execute Action',description:'Run the selected action on the target container. Effects are immediate.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-6d71d041030d570b',popover:{title:'5-4. Kill ALL',description:'Force-stop every running sensor container at once. Use with caution.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-group-ui_group_sensors_list',popover:{title:'Active Sensors',description:'Live overview of every running sensor container and its status.',side:'top',align:'start'}},\n{element:'#nrdb-ui-widget-338566eff2953ae6',popover:{title:'6-1. Live Nodes Table',description:'Shows container ID, status, IP address, and uptime. Refreshes automatically.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-group-ui_group_sensor_monitor',popover:{title:'Live Sensor Feed',description:'Monitor real-time MQTT data streaming from your deployed sensors.',side:'top',align:'start'}},\n{element:'#nrdb-ui-widget-1453f448f840983f',popover:{title:'7-1. Select Sensor',description:'Pick which running sensor to monitor. Data appears in the terminal below.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-d321091dc35acb56',popover:{title:'7-2. Start',description:'Begin monitoring. Live MQTT data streams into the terminal below.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-8ad272094d5c84de',popover:{title:'7-3. Stop',description:'Stop the live feed. Terminal freezes showing the last received data.',side:'bottom',align:'start'}},\n{element:'#nrdb-ui-widget-b577b406436de1c3',popover:{title:'7-4. Data Terminal',description:'Displays live MQTT messages: sensor type, value, timestamp, and unit.',side:'left',align:'start'}}\n        ],\n        onDestroyed:function(){ localStorage.setItem('tour_nm_done','1'); },\n        onCloseClick:function(){ localStorage.setItem('tour_nm_done','1'); d.destroy(); }\n      });\n      d.drive();\n    },1200);\n  };\n  document.head.appendChild(s);\n})();\n\">",
