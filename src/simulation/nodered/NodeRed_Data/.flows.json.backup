    {
        "id": "dbe78305fe67ba53",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Prep Request",
        "func": "let target_node = flow.get('cfg_target_node');\nlet action = flow.get('cfg_target_action');\nif(!target_node || !action) { return [null, { payload: '⚠️ Select Node and Action' }]; }\n\nif(action === 'delete') {\n    msg.method = 'DELETE';\n    msg.url = 'http://docker-proxy:2375/containers/' + target_node + '?force=true';\n} else if (action === 'kill') {\n    msg.method = 'POST';\n    msg.url = 'http://docker-proxy:2375/containers/' + target_node + '/kill';\n} else {\n    msg.method = 'POST';\n    msg.url = 'http://docker-proxy:2375/containers/' + target_node + '/' + action;\n}\nlet log = { payload: `Executing ${action.toUpperCase()} on node: ${target_node}...` };\nreturn [msg, log];",
        "outputs": 2,
        "x": 340,
        "y": 980,
        "wires": [
            [
                "1ec3ece025157cb1"
            ],
