    {
        "id": "6f9de8b348f9d7b7",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Build Docker Cmd",
        "func": "let cfg = msg.payload;\n\nmsg.sensor_config = cfg;\nmsg.url = 'http://docker-proxy:2375/containers/create?name=' + cfg.id;\nmsg.payload = {\n    \"Image\": \"iot-sensor\",\n    \"Env\": [\n        \"SENSOR_ID=\" + cfg.id,\n        \"SENSOR_TYPES=\" + cfg.types,\n        \"NODE_PROFILE=\" + cfg.profile,\n        \"INTERVAL=\" + cfg.interval,\n        \"MQTT_BROKER=mosquitto\"\n    ],\n    \"HostConfig\": {\n        \"NetworkMode\": \"iot_infralab_net\",\n        \"AutoRemove\": true,\n        \"Binds\": [\"D:/IoT_InfraLab/config:/app/config\"]\n    }\n};\nreturn msg;",
        "outputs": 1,
        "x": 210,
        "y": 500,
        "wires": [
            [
                "4f43f5aa75c75965"
            ]
        ]
    },
