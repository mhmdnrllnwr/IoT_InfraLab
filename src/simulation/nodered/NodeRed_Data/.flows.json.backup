    {
        "id": "dc550562aa9db095",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Extract IDs to Kill",
        "func": "let sensors = [];\nif(msg.payload && Array.isArray(msg.payload)){\n    sensors = msg.payload.filter(c => c.Image === 'iot-sensor' || c.Image === 'iot-sensor:latest');\n}\nif(sensors.length === 0) {\n    return [null, { payload: \"↳ No sensors bound...\" }];\n}\nlet msgs = sensors.map(s => {\n    return {\n        url: 'http://docker-proxy:2375/containers/' + s.Id + '?force=true',\n        method: 'DELETE'\n    };\n});\nreturn [msgs, { payload: `↳ Wiping out ${msgs.length} engines...` }];",
