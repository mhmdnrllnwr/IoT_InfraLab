        "name": "Create Exec tail",
        "func": "msg.url = 'http://docker-proxy:2375/containers/suricata-ids/exec';\nmsg.method = 'POST';\nmsg.headers = { 'Content-Type': 'application/json' };\nmsg.payload = {\n    'AttachStdout': true,\n    'Tty': true,\n    'Cmd': ['sh', '-c', 'grep \\\"\\\\\"event_type\\\\\":\\\\\"alert\\\\\"\\\" /var/log/suricata/eve.json | tail -n 15']\n};\nreturn msg;",
