    {
        "id": "fe5f944518faeb35",
        "type": "http request",
        "z": "53b83243ce3bfc91",
        "name": "GET Containers",
        "method": "GET",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://docker-proxy:2375/containers/json?all=true",
        "tls": "",
        "persist": false,
        "proxy": "",
        "authType": "",
        "senderr": false,
        "x": 300,
