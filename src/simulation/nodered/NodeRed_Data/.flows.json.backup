    {
        "id": "42a84a202cae8c2b",
        "type": "ui-button",
        "z": "89c26b2630a7d108",
        "group": "ui_group_create",
        "name": "Save Config Btn",
        "label": "Deploy & Save",
        "order": 5,
        "width": 3,
        "height": 0,
        "tooltip": "Save config and deploy node",
        "color": "white",
        "bgcolor": "#3b82f6",
        "className": "",
        "icon": "save",
        "payload": "save",
        "payloadType": "str",
        "topic": "topic",
        "topicType": "msg",
        "x": 120,
        "y": 360,
        "wires": [
            [
                "3322adde400100f4"
            ]
        ]
    },
    {
        "id": "fe3cc3695fdbea2d",
        "type": "ui-button",
        "z": "89c26b2630a7d108",
        "group": "ui_group_create",
        "name": "Run Only Btn",
        "label": "Deploy Only",
        "order": 6,
        "width": 3,
        "height": 0,
        "tooltip": "Deploy node without saving config",
        "color": "white",
        "bgcolor": "#10b981",
        "className": "",
        "icon": "play",
        "payload": "run",
        "payloadType": "str",
        "topic": "topic",
        "topicType": "msg",
        "x": 120,
        "y": 400,
        "wires": [
            [
                "3322adde400100f4"
            ]
        ]
    },
    {
        "id": "3322adde400100f4",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Construct Config & Validate",
        "func": "let action = msg.payload || 'save';\nlet n_id = flow.get('cfg_node_id');\nlet s_types = flow.get('cfg_sensors');\nlet prof = flow.get('cfg_profile');\nlet intrvl = flow.get('cfg_interval');\n\nlet errors = [];\nif (!n_id || n_id.trim() === '') errors.push(\"⚠️ Validation Error: Node ID is missing!\");\nif (!s_types || s_types.length === 0) errors.push(\"⚠️ Validation Error: Sensor Types not selected!\");\nif (!prof || prof.trim() === '') errors.push(\"⚠️ Validation Error: Behavior Profile not selected!\");\n\nif (errors.length > 0) {\n    return [null, null, { payload: errors.join('\\n') }];\n}\n\nif (Array.isArray(s_types)) s_types = s_types.join(',');\nintrvl = intrvl || 5;\n\nmsg.new_config = {\n    id: n_id,\n    types: s_types,\n    profile: prof,\n    interval: intrvl,\n    saved_at: new Date().toISOString()\n};\n\nmsg.payload = msg.new_config;\n\nif (action === 'run') {\n    let logMsg = { payload: `🚀 Deploying Node [${n_id}] directly (Run Only)...` };\n    return [null, msg, logMsg];\n} else {\n    return [msg, null, null];\n}",
        "outputs": 3,
        "x": 360,
        "y": 360,
        "wires": [
            [
                "7cf3b44f7e607176"
            ],
            [
                "6f9de8b348f9d7b7"
            ],
            [
                "d7dfe950f06ff51b"
            ]
        ]
    },
    {
        "id": "7cf3b44f7e607176",
        "type": "file in",
        "z": "89c26b2630a7d108",
        "name": "Read Configs (Check)",
        "filename": "/data/saved_sensors.json",
        "filenameType": "str",
        "format": "utf8",
        "x": 600,
        "y": 340,
        "wires": [
            [
                "b5e202ac0989d43a"
            ]
        ]
    },
    {
        "id": "b5e202ac0989d43a",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Check ID & Append",
        "func": "let configs = [];\ntry {\n    if (msg.payload) {\n        configs = JSON.parse(msg.payload);\n    }\n} catch(e) { }\n\n// Check if ID exists!\nlet exists = configs.findIndex(c => c.id === msg.new_config.id);\nif (exists >= 0) {\n    // HALT operation on fail\n    return [null, null, { payload: `❌ FAILED: Saved Configuration '${msg.new_config.id}' already exists!` }];\n}\n\nconfigs.push(msg.new_config);\nmsg.payload = JSON.stringify(configs, null, 2);\n\n// Returns [save command, next docker deploy step, log/error msg]\nreturn [msg, { payload: msg.new_config }, { payload: `✅ Configuration [${msg.new_config.id}] saved... Dispatching deployment.`}];",
        "outputs": 3,
        "x": 810,
        "y": 340,
        "wires": [
            [
                "06b717e37ca66f07"
            ],
            [
                "6f9de8b348f9d7b7"
            ],
            [
                "d7dfe950f06ff51b",
                "ee847efb50e50319"
            ]
        ]
    },
    {
        "id": "06b717e37ca66f07",
        "type": "file",
        "z": "89c26b2630a7d108",
        "name": "Write Configs",
        "filename": "/data/saved_sensors.json",
        "appendNewline": true,
        "overwriteFile": "true",
        "x": 1000,
        "y": 300,
        "wires": [
            [
                "417256df7d7f068b"
            ]
        ]
    },
    {
        "id": "ee847efb50e50319",
        "type": "ui-notification",
        "z": "89c26b2630a7d108",
        "ui": "8bcc34ca17387ebb",
        "position": "top right",
        "color": "#facc15",
        "displayTime": "3",
        "showCountdown": true,
        "outputs": 1,
        "allowDismiss": true,
        "raw": false,
        "className": "",
        "name": "Saved Alert",
