    {
        "id": "23b437e91f3ea332",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "CRUD Logic Engine",
        "func": "let db = global.get('sensorTypesDB') || {};\n\nif (msg.topic === \"save\") {\n    let d = msg.payload;\n    let safeName = d.typeName.toLowerCase().replace(/ /g, \"_\");\n    \n    db[safeName] = {\n        range: [parseFloat(d.min), parseFloat(d.max)]\n    };\n}\nelse if (msg.topic === \"delete\") {\n    let selectedId = global.get('lastSelectedId');\n    if(selectedId && db[selectedId]) {\n        delete db[selectedId];\n    }\n}\n\nmsg.payload = JSON.stringify(db, null, 2);\nmsg.topic = \"cmd/system/reload\";\nreturn msg;",
        "outputs": 1,
        "x": 3020,
        "y": 100,
        "wires": [
