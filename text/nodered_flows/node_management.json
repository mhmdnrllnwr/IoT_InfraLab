        "type": "function",
        "z": "c350aeb8fed5a51f",
        "name": "Parse Live Nodes",
        "func": "let html = '<table style=\"width:100%; text-align:left; border-collapse:collapse;\"><tr style=\"border-bottom:1px solid #555;\"><th style=\"padding:4px;\">Node ID</th><th style=\"padding:4px;\">State</th><th style=\"padding:4px;\">Status</th></tr>';\nlet opts = [];\nif(msg.payload && Array.isArray(msg.payload)){\n    let sensors = msg.payload.filter(c => c.Image === 'iot-sensor' || c.Image === 'iot-sensor:latest');\n    sensors.forEach(c => {\n        let name = c.Names[0].replace('/','');\n        let status = c.Status;\n        let state = c.State;\n        let color = state === 'running' ? '#10b981' : (state === 'paused' ? '#f59e0b' : '#ef4444');\n        if(state === 'exited') color = '#ef4444';\n        html += `<tr style=\"border-bottom:1px solid #333;\"><td style=\"padding:4px;\">${name}</td><td style=\"padding:4px;color:${color}\">${state}</td><td style=\"padding:4px;font-size:0.85em;color:#aaa;\">${status}</td></tr>`;\n        opts.push({label: name, value: name, type: 'str'});\n    });\n    if(sensors.length === 0) {\n        html += '<tr><td colspan=\"3\" style=\"text-align:center;padding:10px;\">No sensors actively running</td></tr>';\n        opts.push({label: \"No Active Nodes\", value: \"none\", type: \"str\"});\n    }\n}\nhtml += '</table>';\nreturn [{payload: html}, {options: opts}];",
