    {
        "id": "0c845e846f767f0e",
        "type": "function",
        "z": "53b83243ce3bfc91",
        "name": "2. Save & Prep Suricata Cat",
        "func": "// Strip hidden Docker control characters to ensure clean text\nlet cleanMosq = msg.payload.replace(/[^\\x20-\\x7E\\n\\r]/g, \"\");\n// Remove empty lines for a tighter UI\ncleanMosq = cleanMosq.split('\\n').filter(line => line.trim() !== '').join('\\n');\n\n// Store Mosquitto output safely while we fetch Suricata\nmsg.mosq_conf = cleanMosq;\n\n// Prepare Suricata command\nmsg.url = \"http://docker-proxy:2375/containers/suricata-ids/exec\";\nmsg.method = \"POST\";\nmsg.payload = {\n    \"AttachStdout\": true,\n    \"Tty\": true,\n    \"Cmd\": [\"cat\", \"/etc/suricata/rules/local.rules\"]\n};\nreturn msg;",
        "outputs": 1,
