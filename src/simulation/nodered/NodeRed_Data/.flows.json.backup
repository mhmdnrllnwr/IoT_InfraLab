    {
        "id": "5a9e7b1d4c3ffce4",
        "type": "ui-template",
        "z": "53b83243ce3bfc91",
        "group": "1384ea55c0ba1905",
        "page": "",
        "ui": "",
        "name": "SOC Log View",
        "order": 1,
        "width": "0",
        "height": "0",
        "format": "<template>\n    <div class=\"soc-container\">\n        \n        <div class=\"sys-logs-wrapper\">\n            <div class=\"sys-log-header\">\n                <v-icon icon=\"mdi-console-line\" class=\"icon-space\"></v-icon> SOC AUDIT LOG (ACTIONS & ALERTS)\n            </div>\n            <div class=\"sys-log-content\">\n                <div v-if=\"logs.length === 0\" style=\"color: #64748b;\">Awaiting operator actions...</div>\n                <div v-for=\"(log, index) in logs\" :key=\"index\" class=\"log-entry\">\n                    <span class=\"log-time\">{{ log.time }}</span> \n                    <span class=\"log-msg\">{{ log.text }}</span>\n                </div>\n            </div>\n        </div>\n\n        \n        <div v-if=\"!configs?.mosquitto\" class=\"waiting\">\n            Awaiting live configuration sync...\n        </div>\n        \n        <div v-else class=\"tables-wrapper\">\n            <table class=\"soc-table mosq-table\">\n                <thead>\n                    <tr>\n                        <th>\n                            <v-icon icon=\"mdi-message-text-outline\" class=\"icon-space\"></v-icon> \n                            iot_broker : /mosquitto/config/mosquitto.conf\n                        </th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td><pre>{{ configs.mosquitto }}</pre></td>\n                    </tr>\n                </tbody>\n            </table>\n\n            <table class=\"soc-table suri-table\">\n                <thead>\n                    <tr>\n                        <th>\n                            <v-icon icon=\"mdi-shield-check\" class=\"icon-space\"></v-icon> \n                            suricata-ids : /etc/suricata/rules/local.rules\n                        </th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td><pre>{{ configs.suricata }}</pre></td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n    </div>\n</template>\n\n<script>\nexport default {\n    data() {\n        return {\n            configs: { mosquitto: '', suricata: '' },\n            logs: []\n        }\n    },\n    watch: {\n        msg: {\n            deep: true,\n            handler(newMsg) {\n                if (!newMsg) return;\n                \n                // Handle new System Log Events\n                if (newMsg.topic === 'system_log') {\n                    const timeStr = new Date().toLocaleTimeString();\n                    this.logs.unshift({ time: `[${timeStr}]`, text: newMsg.payload });\n                    \n                    // Keep only the last 8 events to prevent the UI from getting too tall\n                    if (this.logs.length > 8) this.logs.pop();\n                } \n                // Handle Live Docker Config Polling\n                else if (newMsg.payload && newMsg.payload.mosquitto !== undefined) {\n                    this.configs = newMsg.payload;\n                }\n            }\n        }\n    }\n}\n</script>\n\n<style>\n/* Base Container */\n.soc-container {\n    width: 100%;\n    height: 100%;\n    padding: 15px;\n    background-color: #121212;\n    border-radius: 6px;\n    box-sizing: border-box;\n    overflow-y: auto;\n}\n.waiting {\n    text-align: center;\n    color: #64748b;\n    margin-top: 20px;\n    font-family: sans-serif;\n}\n.tables-wrapper {\n    display: flex;\n    flex-direction: column;\n    gap: 20px;\n}\n\n/* Global Table Styles */\n.soc-table {\n    width: 100%;\n    border-collapse: collapse;\n    font-family: sans-serif;\n    background-color: #1e293b;\n    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.5);\n}\n.soc-table th {\n    padding: 12px;\n    text-align: left;\n    color: #f1f5f9;\n    font-size: 14px;\n    font-weight: 600;\n}\n.soc-table td {\n    background-color: #0f172a;\n    padding: 15px;\n}\n.soc-table pre {\n    margin: 0;\n    font-family: monospace;\n    white-space: pre-wrap;\n    word-wrap: break-word;\n    font-size: 13px;\n}\n.icon-space { margin-right: 8px; }\n\n/* Mosquitto Specific Colors */\n.mosq-table th { border-left: 4px solid #3b82f6; }\n.mosq-table th .v-icon { color: #3b82f6; }\n.mosq-table pre { color: #38bdf8; }\n\n/* Suricata Specific Colors */\n.suri-table th { border-left: 4px solid #ef4444; }\n.suri-table th .v-icon { color: #ef4444; }\n.suri-table pre { color: #10b981; }\n\n/* --- NEW: System Logs Styles --- */\n.sys-logs-wrapper {\n    margin-bottom: 20px;\n    background-color: #1e293b;\n    border-radius: 4px;\n    border-left: 4px solid #f59e0b; /* Amber alert color */\n    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.5);\n}\n.sys-log-header {\n    padding: 10px 12px;\n    color: #f1f5f9;\n    font-weight: 600;\n    font-size: 14px;\n    background-color: rgba(0,0,0,0.2);\n    border-bottom: 1px solid #334155;\n}\n.sys-log-content {\n    padding: 12px;\n    font-family: monospace;\n    font-size: 13px;\n    max-height: 140px;\n    overflow-y: auto;\n}\n.log-entry { margin-bottom: 6px; }\n.log-time { color: #94a3b8; margin-right: 8px; }\n.log-msg { color: #fbbf24; }\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
