        "id": "856603363f3089d0",
        "type": "function",
        "z": "89c26b2630a7d108",
        "name": "Fill Form Info",
        "func": "let typeName = msg.payload;\nglobal.set('lastSelectedId', typeName);\nlet db = global.get('sensorTypesDB') || {};\n\nif (typeName && db[typeName]) {\n    msg.payload = {\n        typeName: typeName,\n        min: db[typeName].range[0],\n        max: db[typeName].range[1]\n    };\n    return msg;\n} return null;",
        "outputs": 1,
        "x": 2550,
        "y": 80,
