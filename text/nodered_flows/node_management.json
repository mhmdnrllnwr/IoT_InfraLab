        "name": "Route by Action",
        "property": "action_type",
        "propertyType": "msg",
        "rules": [
            { "t": "eq", "v": "run_save", "vt": "str" },
            { "t": "eq", "v": "run_only", "vt": "str" }
        ],
        "checkall": "true",
        "repair": false,
        "outputs": 2,
