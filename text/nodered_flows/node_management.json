    {
        "id": "22be8fab2e72050e",
        "type": "function",
        "z": "c350aeb8fed5a51f",
        "name": "Construct Config",
        "func": "let n_id = flow.get('cfg_node_id');\nif(!n_id || typeof n_id !== 'string' || !n_id.trim()) {\n    return [null, { payload: '⚠️ [VALIDATION FAILED] Node ID is required to save/run.' }];\n}\n\nif(n_id.length > 30) {\n    return [null, { payload: '⚠️ [VALIDATION FAILED] Node ID must not exceed 30 characters.' }];\n}\n\nlet regex = /^[a-zA-Z0-9][a-zA-Z0-9_.-]+$/;\nif(!regex.test(n_id)) {\n    return [null, { payload: '⚠️ [VALIDATION FAILED] Node ID has invalid characters. Use alphanumeric, dash, or underscore.' }];\n}\n\nlet s_types = flow.get('cfg_sensors');\nif (!s_types || (Array.isArray(s_types) && s_types.length === 0)) {\n    return [null, { payload: '⚠️ [VALIDATION FAILED] At least one Sensor Type must be selected.' }];\n}\nif (Array.isArray(s_types)) s_types = s_types.join(',');\n\nlet prof = flow.get('cfg_profile');\nif(!prof || prof === 'none') {\n    return [null, { payload: '⚠️ [VALIDATION FAILED] Behavior Profile must be selected.' }];\n}\n\nlet intrvl = flow.get('cfg_interval') || 5;\n\nmsg.new_config = {\n    id: n_id,\n    types: s_types,\n    profile: prof,\n    interval: intrvl,\n    saved_at: new Date().toISOString()\n};\n\n// Check if this run was triggered by Run & Save or Run Only\nmsg.action_type = msg.payload || 'run_save'; \n\nreturn [msg, null];",
        "outputs": 2,
        "x": 350,
        "y": 360,
        "wires": [
            [
                "router_save_vs_run"
            ],
            [
                "41f32fc1c4201df6"
            ]
        ]
    },
    {
        "id": "router_save_vs_run",
        "type": "switch",
