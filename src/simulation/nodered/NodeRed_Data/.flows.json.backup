    {
        "id": "2c185cf0420c3e4c",
        "type": "function",
        "z": "53b83243ce3bfc91",
        "name": "3. Format SOC Terminal",
        "func": "let cleanSuri = msg.payload.replace(/[^\\x20-\\x7E\\n\\r]/g, \"\");\ncleanSuri = cleanSuri.split('\\n').filter(line => line.trim() !== '').join('\\n');\nlet mosq = msg.mosq_conf;\n\n// Send pure data to the Vue template\nmsg.payload = {\n    mosquitto: mosq,\n    suricata: cleanSuri\n};\n\n// CRITICAL: Force the topic so the UI knows this is file data\nmsg.topic = \"live_configs\";\n\nreturn msg;",
