# --- Node-RED Dynamic Data & Secrets ---
# We keep flows.json and package.json (code), but ignore secrets and installed modules
src/simulation/nodered/NodeRed_Data/*_cred.json
src/simulation/nodered/NodeRed_Data/*_cred.json.backup
src/simulation/nodered/NodeRed_Data/.flows.json.backup
src/simulation/nodered/NodeRed_Data/.config.*.json
src/simulation/nodered/NodeRed_Data/.config.*.json.backup
src/simulation/nodered/NodeRed_Data/.sessions.json
src/simulation/nodered/NodeRed_Data/node_modules/
src/simulation/nodered/NodeRed_Data/.npm/

# --- Suricata Runtime & Logs ---
infrastructure/suricata/run/*
!infrastructure/suricata/run/.gitkeep
infrastructure/suricata/logs/*
!infrastructure/suricata/logs/.gitkeep

