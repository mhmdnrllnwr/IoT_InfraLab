        "func": "if(msg.statusCode === 200) {\n    msg.payload = \"✅ SUCCESS: Attacker IP has been physically disconnected from the IoT Network.\\nReconnaissance and Lateral Movement neutralized.\";\n} else {\n    msg.payload = \"❌ FAILED: Could not isolate IP. Error Status: \" + msg.statusCode + \"\\n\" + msg.payload;\n}\nreturn msg;",
